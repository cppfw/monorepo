{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "$comment": [
        "base preset"
      ],
      "hidden": true,
      "name": "base",
      "description": "Base preset to be inherited by all presets",
      "binaryDir": "${sourceDir}/../../out/${presetName}/"
    },
    {
      "name": "rel",
      "inherits": "base",
      "description": "host platform native config, not cross-building, release build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dbg",
      "inherits": "base",
      "description": "host platform native config, not cross-building, debug build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ios-dbg",
      "inherits": "base",
      "description": "cross-building on macos for ios, debug build",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ios-rel",
      "inherits": "base",
      "description": "cross-building on macos for ios, release build",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "$comment": [
        "base preset"
      ],
      "hidden": true,
      "name": "base",
      "jobs": 0
    },
    {
      "$comment": [
        "native debug preset"
      ],
      "hidden": false,
      "name": "dbg",
      "inherits": "base",
      "configurePreset": "dbg",
      "configuration": "Debug"
    },
    {
      "$comment": [
        "native release preset"
      ],
      "hidden": false,
      "name": "rel",
      "inherits": "base",
      "configurePreset": "rel",
      "configuration": "Release"
    },
    {
      "$comment": [
        "ios-base preset"
      ],
      "hidden": true,
      "name": "ios",
      "inherits": "base",
      "configurePreset": "ios",
      "nativeToolOptions": [
        "-sdk", "iphonesimulator",
        "-arch", "arm64"
      ]
    },
    {
      "$comment": [
        "ios debug preset"
      ],
      "hidden": false,
      "name": "ios-dbg",
      "inherits": "ios",
      "configurePreset": "ios-dbg",
      "configuration": "Debug"
    },
    {
      "$comment": [
        "ios release preset"
      ],
      "hidden": false,
      "name": "ios-rel",
      "inherits": "ios",
      "configurePreset": "ios-rel",
      "configuration": "Release"
    }
  ]
}
